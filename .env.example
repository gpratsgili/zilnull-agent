# ZIL⌀ Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model to use for all pipeline stages (override per-stage in config.py if needed)
ZIL_MODEL=gpt-5.4

# ── Paths ─────────────────────────────────────────────────────────────────────
# Root for all machine-local state (conversations, memory layers)
ZIL_STATE_DIR=vessel/state/zil

# ── Budget ────────────────────────────────────────────────────────────────────
# Maximum charge units allowed per session before ZIL asks before widening
ZIL_SESSION_BUDGET=50

# ── Audit ─────────────────────────────────────────────────────────────────────
# Minimum score (0.0–1.0) below which auditor blocks the response
ZIL_AUDIT_BLOCK_THRESHOLD=0.35

# Minimum score below which auditor requests revision before sending
ZIL_AUDIT_REVISE_THRESHOLD=0.60

# ── Memory ────────────────────────────────────────────────────────────────────
# Number of turns kept in rolling window memory
ZIL_WINDOW_SIZE=8

# Number of window memory records injected into the system prompt each turn
ZIL_CONTEXT_WINDOW_RECORDS=20

# ── Web search (one required to use web_search tool) ──────────────────────────
# Brave Search API: https://brave.com/search/api/
# BRAVE_API_KEY=...

# Tavily Search API: https://tavily.com/
# TAVILY_API_KEY=...

# ── Debug ─────────────────────────────────────────────────────────────────────
ZIL_DEBUG=false
ZIL_SHOW_PIPELINE=false
